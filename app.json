{
  "expo": {
    "name": "Table Red Oaxaca Wallet",
    "slug": "tableredoaxaca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-table.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.jairoboss.tableredoaxaca"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Moteritos App to use your location."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The application accesses your photos to allow you to upload your personal file."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "La app necesita acceso a la cámara para escanear códigos de barras del inventario."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3712610d-4dd9-42dd-8985-1650b432e282"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3712610d-4dd9-42dd-8985-1650b432e282"
    }
  }
}
